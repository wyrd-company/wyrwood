{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrd.company/wyrwood/control-message.schema.json",
  "title": "Wyrwood control protocol version 1",
  "oneOf": [{ "$ref": "#/$defs/request" }, { "$ref": "#/$defs/response" }],
  "$defs": {
    "request": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "operation"],
          "properties": {
            "version": { "const": 1 },
            "operation": { "enum": ["apply", "keys", "status"] }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "operation", "limit"],
          "properties": {
            "version": { "const": 1 },
            "operation": { "const": "events" },
            "limit": { "type": "integer", "minimum": 1, "maximum": 1000 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "operation", "offset", "limit"],
          "properties": {
            "version": { "const": 1 },
            "operation": { "const": "configuration" },
            "offset": { "const": 0 },
            "limit": { "type": "integer", "minimum": 1, "maximum": 16 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "operation", "offset", "limit", "expected_revision"],
          "properties": {
            "version": { "const": 1 },
            "operation": { "const": "configuration" },
            "offset": { "type": "integer", "minimum": 1 },
            "limit": { "type": "integer", "minimum": 1, "maximum": 16 },
            "expected_revision": { "$ref": "#/$defs/revision" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "operation", "expected_revision", "upstream"],
          "properties": {
            "version": { "const": 1 },
            "operation": { "const": "set-upstream" },
            "expected_revision": { "$ref": "#/$defs/revision" },
            "upstream": { "$ref": "#/$defs/absolute-path" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "operation", "expected_revision", "timeouts"],
          "properties": {
            "version": { "const": 1 },
            "operation": { "const": "set-timeouts" },
            "expected_revision": { "$ref": "#/$defs/revision" },
            "timeouts": { "$ref": "#/$defs/timeouts" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "operation", "expected_revision", "consumer"],
          "properties": {
            "version": { "const": 1 },
            "operation": { "const": "put-consumer" },
            "expected_revision": { "$ref": "#/$defs/revision" },
            "consumer_id": { "type": "string", "minLength": 1, "maxLength": 128 },
            "consumer": { "$ref": "#/$defs/configuration-consumer-input" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "operation", "expected_revision", "consumer_id"],
          "properties": {
            "version": { "const": 1 },
            "operation": { "const": "retire-consumer" },
            "expected_revision": { "$ref": "#/$defs/revision" },
            "consumer_id": { "type": "string", "minLength": 1, "maxLength": 128 }
          }
        }
      ]
    },
    "error": {
      "enum": [
        "none",
        "bad-request",
        "unsupported-version",
        "apply-invalid",
        "apply-failed",
        "configuration-invalid",
        "configuration-conflict",
        "configuration-not-found",
        "configuration-failed",
        "configuration-durability-uncertain",
        "upstream-unavailable",
        "resource-limit",
        "internal"
      ]
    },
    "revision": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "absolute-path": { "type": "string", "minLength": 2, "maxLength": 107, "pattern": "^/" },
    "duration": { "type": "string", "minLength": 2, "maxLength": 64 },
    "timeouts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["connect", "list", "replay", "sign"],
      "properties": {
        "connect": { "$ref": "#/$defs/duration" },
        "list": { "$ref": "#/$defs/duration" },
        "replay": { "$ref": "#/$defs/duration" },
        "sign": { "$ref": "#/$defs/duration" }
      }
    },
    "configuration-consumer-input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "socket", "fingerprints"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 256 },
        "socket": { "$ref": "#/$defs/absolute-path" },
        "access_group": { "type": "integer", "minimum": 0, "maximum": 4294967294 },
        "fingerprints": {
          "type": "array",
          "maxItems": 1024,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/fingerprint" }
        }
      }
    },
    "configuration-consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "socket", "fingerprints"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "name": { "type": "string", "minLength": 1, "maxLength": 256 },
        "socket": { "$ref": "#/$defs/absolute-path" },
        "access_group": { "type": "integer", "minimum": 0, "maximum": 4294967294 },
        "fingerprints": {
          "type": "array",
          "maxItems": 1024,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/fingerprint" }
        }
      }
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^SHA256:[A-Za-z0-9+/]{42}[AEIMQUYcgkosw048]$"
    },
    "health": { "enum": ["healthy", "degraded", "unavailable"] },
    "key": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fingerprint", "display"],
      "properties": {
        "fingerprint": {
          "$ref": "#/$defs/fingerprint"
        },
        "display": { "type": "string", "maxLength": 256 }
      }
    },
    "consumer-status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "listener", "active_connections"],
      "properties": {
        "id": { "type": "string", "maxLength": 128 },
        "name": { "type": "string", "maxLength": 256 },
        "listener": { "$ref": "#/$defs/health" },
        "active_connections": { "type": "integer", "minimum": 0 }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "consumer_id",
        "operation",
        "outcome",
        "latency_ns",
        "error_code"
      ],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "consumer_id": { "type": "string", "maxLength": 128 },
        "operation": {
          "enum": [
            "consumer-connect",
            "list-identities",
            "sign",
            "session-bind",
            "upstream-connect",
            "replay",
            "reconcile"
          ]
        },
        "fingerprint": {
          "type": "string",
          "pattern": "^SHA256:[A-Za-z0-9+/]{42}[AEIMQUYcgkosw048]$"
        },
        "outcome": { "enum": ["succeeded", "denied", "failed"] },
        "latency_ns": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9223372036854775807
        },
        "error_code": {
          "enum": [
            "none",
            "policy-denied",
            "upstream-unavailable",
            "upstream-timeout",
            "upstream-protocol",
            "consumer-protocol",
            "resource-limit",
            "internal"
          ]
        }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "ok", "error"],
      "oneOf": [
        {
          "properties": {
            "ok": { "const": false },
            "error": {
              "enum": [
                "bad-request",
                "unsupported-version",
                "apply-invalid",
                "apply-failed",
                "configuration-invalid",
                "configuration-conflict",
                "configuration-not-found",
                "configuration-failed",
                "configuration-durability-uncertain",
                "upstream-unavailable",
                "resource-limit",
                "internal"
              ]
            }
          },
          "not": {
            "anyOf": [
              { "required": ["apply"] },
              { "required": ["keys"] },
              { "required": ["status"] },
              { "required": ["events"] },
              { "required": ["configuration"] },
              { "required": ["configuration_change"] }
            ]
          }
        },
        {
          "required": ["apply"],
          "properties": {
            "ok": { "const": true },
            "error": { "const": "none" }
          },
          "not": {
            "anyOf": [
              { "required": ["keys"] },
              { "required": ["status"] },
              { "required": ["events"] },
              { "required": ["configuration"] },
              { "required": ["configuration_change"] }
            ]
          }
        },
        {
          "required": ["keys"],
          "properties": {
            "ok": { "const": true },
            "error": { "const": "none" }
          },
          "not": {
            "anyOf": [
              { "required": ["apply"] },
              { "required": ["status"] },
              { "required": ["events"] },
              { "required": ["configuration"] },
              { "required": ["configuration_change"] }
            ]
          }
        },
        {
          "required": ["status"],
          "properties": {
            "ok": { "const": true },
            "error": { "const": "none" }
          },
          "not": {
            "anyOf": [
              { "required": ["apply"] },
              { "required": ["keys"] },
              { "required": ["events"] },
              { "required": ["configuration"] },
              { "required": ["configuration_change"] }
            ]
          }
        },
        {
          "required": ["events"],
          "properties": {
            "ok": { "const": true },
            "error": { "const": "none" }
          },
          "not": {
            "anyOf": [
              { "required": ["apply"] },
              { "required": ["keys"] },
              { "required": ["status"] },
              { "required": ["configuration"] },
              { "required": ["configuration_change"] }
            ]
          }
        },
        {
          "required": ["configuration"],
          "properties": {
            "ok": { "const": true },
            "error": { "const": "none" }
          },
          "not": {
            "anyOf": [
              { "required": ["apply"] },
              { "required": ["keys"] },
              { "required": ["status"] },
              { "required": ["events"] },
              { "required": ["configuration_change"] }
            ]
          }
        },
        {
          "required": ["configuration_change"],
          "properties": {
            "ok": { "const": true },
            "error": { "const": "none" }
          },
          "not": {
            "anyOf": [
              { "required": ["apply"] },
              { "required": ["keys"] },
              { "required": ["status"] },
              { "required": ["events"] },
              { "required": ["configuration"] }
            ]
          }
        }
      ],
      "properties": {
        "version": { "const": 1 },
        "ok": { "type": "boolean" },
        "error": { "$ref": "#/$defs/error" },
        "apply": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "revision",
            "committed",
            "degraded",
            "pending_cleanup",
            "pending_permissions"
          ],
          "properties": {
            "revision": { "$ref": "#/$defs/revision" },
            "committed": { "type": "boolean" },
            "degraded": { "type": "boolean" },
            "pending_cleanup": { "type": "integer", "minimum": 0 },
            "pending_permissions": { "type": "integer", "minimum": 0 }
          }
        },
        "keys": {
          "type": "object",
          "additionalProperties": false,
          "required": ["keys"],
          "properties": {
            "keys": {
              "type": "array",
              "maxItems": 1024,
              "items": { "$ref": "#/$defs/key" }
            }
          }
        },
        "status": {
          "type": "object",
          "additionalProperties": false,
          "required": ["active_revision", "daemon", "upstream", "consumers", "truncated"],
          "properties": {
            "active_revision": { "$ref": "#/$defs/revision" },
            "daemon": { "$ref": "#/$defs/health" },
            "upstream": { "$ref": "#/$defs/health" },
            "consumers": {
              "type": "array",
              "maxItems": 512,
              "items": { "$ref": "#/$defs/consumer-status" }
            },
            "truncated": { "type": "boolean" }
          }
        },
        "events": {
          "type": "object",
          "additionalProperties": false,
          "required": ["events"],
          "properties": {
            "events": {
              "type": "array",
              "maxItems": 1000,
              "items": { "$ref": "#/$defs/event" }
            }
          }
        },
        "configuration": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "revision",
            "upstream",
            "timeouts",
            "total_consumers",
            "offset",
            "consumers",
            "complete"
          ],
          "properties": {
            "revision": { "$ref": "#/$defs/revision" },
            "upstream": { "$ref": "#/$defs/absolute-path" },
            "timeouts": { "$ref": "#/$defs/timeouts" },
            "total_consumers": { "type": "integer", "minimum": 0 },
            "offset": { "type": "integer", "minimum": 0 },
            "consumers": {
              "type": "array",
              "maxItems": 16,
              "items": { "$ref": "#/$defs/configuration-consumer" }
            },
            "complete": { "type": "boolean" }
          }
        },
        "configuration_change": {
          "type": "object",
          "additionalProperties": false,
          "required": ["revision", "changed"],
          "properties": {
            "revision": { "$ref": "#/$defs/revision" },
            "changed": { "type": "boolean" }
          }
        }
      }
    }
  }
}
