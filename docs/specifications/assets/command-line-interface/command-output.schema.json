{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrd.company/wyrwood/command-output.schema.json",
  "title": "Wyrwood command output version 1",
  "x-relationships": {
    "implements": "command-line-interface",
    "uses": "control-interface"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "command", "ok"],
  "oneOf": [
    {
      "required": ["result"],
      "not": { "required": ["error"] },
      "properties": {
        "command": { "const": "init" },
        "ok": { "const": true },
        "result": { "$ref": "#/$defs/init-result" }
      }
    },
    {
      "required": ["result"],
      "not": { "required": ["error"] },
      "properties": {
        "command": { "const": "apply" },
        "ok": { "const": true },
        "result": { "$ref": "#/$defs/apply-result" }
      }
    },
    {
      "required": ["result"],
      "not": { "required": ["error"] },
      "properties": {
        "command": { "const": "keys" },
        "ok": { "const": true },
        "result": { "$ref": "#/$defs/keys-result" }
      }
    },
    {
      "required": ["result"],
      "not": { "required": ["error"] },
      "properties": {
        "command": { "const": "status" },
        "ok": { "const": true },
        "result": { "$ref": "#/$defs/status-result" }
      }
    },
    {
      "required": ["result"],
      "not": { "required": ["error"] },
      "properties": {
        "command": { "const": "events" },
        "ok": { "const": true },
        "result": { "$ref": "#/$defs/events-result" }
      }
    },
    {
      "required": ["result"],
      "not": { "required": ["error"] },
      "properties": {
        "command": { "const": "configuration-show" },
        "ok": { "const": true },
        "result": { "$ref": "#/$defs/configuration-result" }
      }
    },
    {
      "required": ["result"],
      "not": { "required": ["error"] },
      "properties": {
        "command": {
          "enum": [
            "configuration-set-upstream",
            "configuration-set-timeouts",
            "consumer-put",
            "consumer-retire"
          ]
        },
        "ok": { "const": true },
        "result": { "$ref": "#/$defs/configuration-change-result" }
      }
    },
    {
      "required": ["result"],
      "not": { "required": ["error"] },
      "properties": {
        "command": { "const": "service" },
        "ok": { "const": true },
        "result": { "$ref": "#/$defs/service-result" }
      }
    },
    {
      "required": ["error"],
      "not": { "required": ["result"] },
      "properties": {
        "command": {
          "enum": [
            "init", "apply", "keys", "status", "events",
            "configuration-show", "configuration-set-upstream",
            "configuration-set-timeouts", "consumer-put", "consumer-retire",
            "service"
          ]
        },
        "ok": { "const": false },
        "error": { "$ref": "#/$defs/error-result" }
      }
    }
  ],
  "properties": {
    "version": { "const": 1 },
    "command": {
      "enum": [
        "init", "apply", "keys", "status", "events",
        "configuration-show", "configuration-set-upstream",
        "configuration-set-timeouts", "consumer-put", "consumer-retire",
        "service"
      ]
    },
    "ok": { "type": "boolean" },
    "result": {
      "oneOf": [
        { "$ref": "#/$defs/init-result" },
        { "$ref": "#/$defs/apply-result" },
        { "$ref": "#/$defs/keys-result" },
        { "$ref": "#/$defs/status-result" },
        { "$ref": "#/$defs/events-result" },
        { "$ref": "#/$defs/configuration-result" },
        { "$ref": "#/$defs/configuration-change-result" },
        { "$ref": "#/$defs/service-result" }
      ]
    },
    "error": { "$ref": "#/$defs/error-result" }
  },
  "$defs": {
    "revision": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "health": { "enum": ["healthy", "degraded", "unavailable"] },
    "fingerprint": {
      "type": "string",
      "pattern": "^SHA256:[A-Za-z0-9+/]{42}[AEIMQUYcgkosw048]$"
    },
    "init-result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 }
      }
    },
    "apply-result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision", "committed", "degraded", "pending_cleanup", "pending_permissions"],
      "properties": {
        "revision": { "$ref": "#/$defs/revision" },
        "committed": { "const": true },
        "degraded": { "type": "boolean" },
        "pending_cleanup": { "type": "integer", "minimum": 0 },
        "pending_permissions": { "type": "integer", "minimum": 0 }
      }
    },
    "key": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fingerprint", "display"],
      "properties": {
        "fingerprint": { "$ref": "#/$defs/fingerprint" },
        "display": { "type": "string", "maxLength": 256 }
      }
    },
    "keys-result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keys"],
      "properties": {
        "keys": {
          "type": "array",
          "maxItems": 1024,
          "items": { "$ref": "#/$defs/key" }
        }
      }
    },
    "consumer-status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "listener", "active_connections"],
      "properties": {
        "id": { "type": "string", "maxLength": 128 },
        "name": { "type": "string", "minLength": 1, "maxLength": 256 },
        "listener": { "$ref": "#/$defs/health" },
        "active_connections": { "type": "integer", "minimum": 0 }
      }
    },
    "status-result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active_revision", "daemon", "upstream", "consumers", "truncated"],
      "properties": {
        "active_revision": { "$ref": "#/$defs/revision" },
        "daemon": { "$ref": "#/$defs/health" },
        "upstream": { "$ref": "#/$defs/health" },
        "consumers": {
          "type": "array",
          "maxItems": 512,
          "items": { "$ref": "#/$defs/consumer-status" }
        },
        "truncated": { "type": "boolean" }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "consumer_id", "operation", "outcome", "latency_ns", "error_code"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "consumer_id": { "type": "string", "maxLength": 128 },
        "operation": {
          "enum": ["consumer-connect", "list-identities", "sign", "session-bind", "upstream-connect", "replay", "reconcile"]
        },
        "fingerprint": { "$ref": "#/$defs/fingerprint" },
        "outcome": { "enum": ["succeeded", "denied", "failed"] },
        "latency_ns": { "type": "integer", "minimum": 0, "maximum": 9223372036854775807 },
        "error_code": {
          "enum": ["none", "policy-denied", "upstream-unavailable", "upstream-timeout", "upstream-protocol", "consumer-protocol", "resource-limit", "internal"]
        }
      }
    },
    "events-result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["events"],
      "properties": {
        "events": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/event" }
        }
      }
    },
    "timeouts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["connect", "list", "replay", "sign"],
      "properties": {
        "connect": { "type": "string", "minLength": 2, "maxLength": 64 },
        "list": { "type": "string", "minLength": 2, "maxLength": 64 },
        "replay": { "type": "string", "minLength": 2, "maxLength": 64 },
        "sign": { "type": "string", "minLength": 2, "maxLength": 64 }
      }
    },
    "configuration-consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "socket", "fingerprints"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "name": { "type": "string", "minLength": 1, "maxLength": 256 },
        "socket": { "type": "string", "minLength": 2, "maxLength": 107, "pattern": "^/" },
        "access_group": { "type": "integer", "minimum": 0, "maximum": 4294967294 },
        "fingerprints": {
          "type": "array",
          "maxItems": 1024,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/fingerprint" }
        }
      }
    },
    "configuration-result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision", "upstream", "timeouts", "consumers"],
      "properties": {
        "revision": { "$ref": "#/$defs/revision" },
        "upstream": { "type": "string", "minLength": 2, "maxLength": 107, "pattern": "^/" },
        "timeouts": { "$ref": "#/$defs/timeouts" },
        "consumers": {
          "type": "array",
          "items": { "$ref": "#/$defs/configuration-consumer" }
        }
      }
    },
    "configuration-change-result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision", "changed"],
      "properties": {
        "revision": { "$ref": "#/$defs/revision" },
        "changed": { "type": "boolean" }
      }
    },
    "service-result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "installed", "enabled", "state"],
      "oneOf": [
        {
          "properties": {
            "installed": { "const": false },
            "enabled": { "const": false },
            "state": { "const": "not-installed" }
          }
        },
        {
          "properties": {
            "installed": { "const": true },
            "state": { "enum": ["inactive", "active", "failed"] }
          }
        }
      ],
      "properties": {
        "action": { "enum": ["install", "remove", "start", "stop", "status"] },
        "installed": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "state": { "enum": ["not-installed", "inactive", "active", "failed"] }
      }
    },
    "error-result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "action"],
      "properties": {
        "code": {
          "enum": [
            "usage", "initialization-failed", "durability-uncertain", "daemon-unavailable",
            "apply-invalid", "apply-failed", "configuration-invalid",
            "configuration-conflict", "configuration-not-found",
            "configuration-failed", "configuration-durability-uncertain",
            "upstream-unavailable", "resource-limit",
            "request-rejected", "incompatible-daemon", "daemon-failed",
            "service-unavailable", "service-not-installed", "service-failed"
          ]
        },
        "message": { "type": "string", "minLength": 1, "maxLength": 256 },
        "action": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    }
  }
}
